# === Required ===
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=
PINECONE_INDEX_NAME=llm-md-index
PINECONE_ENVIRONMENT=us-east-1

# === Optional: LLM Providers ===
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=
DEFAULT_LLM_TEMPERATURE=0.7

# === Optional: Provider-Specific ===
OPENAI_DEFAULT_MODEL=gpt-4o
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DEFAULT_MAX_TOKENS=4096
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT=120

# === Optional: RAG Settings ===
RAG_DEFAULT_TOP_K=5
RAG_CONTEXT_SCORE_THRESHOLD=0.5
RAG_CONVERSATION_HISTORY_MESSAGES=6

# === Optional: Embedding & Vector DB ===
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=100
EMBEDDING_MAX_RETRIES=3
PINECONE_UPSERT_BATCH_SIZE=100
PINECONE_SIMILARITY_METRIC=cosine
PINECONE_CLOUD_PROVIDER=aws
CHUNK_SIZE=512
CHUNK_OVERLAP=0.2

# === Optional: Redis & Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_URL=redis://localhost:6379/2
JOB_TTL_SECONDS=604800
CONVERSATION_TTL_SECONDS=604800
CELERY_TASK_TIME_LIMIT=3600
CELERY_MAX_RETRIES=3
CELERY_RETRY_BASE_COUNTDOWN=60

# === Optional: Server ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
UPLOAD_MAX_FILE_SIZE=52428800
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# === Optional: Async Processing Thresholds ===
ASYNC_FILE_SIZE_THRESHOLD=102400
ASYNC_CHUNK_COUNT_THRESHOLD=20
