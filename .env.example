# Database
DATABASE_URL=postgresql://llm_user:llm_password@localhost:5432/llm_cli

# JWT Authentication
# CRITICAL: Generate a secure secret with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Must be at least 32 characters. DO NOT use the placeholder below!
JWT_SECRET_KEY=REPLACE_WITH_SECURE_32_CHAR_MINIMUM_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Database Password Encryption
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
DB_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY_44_CHARS

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...  # Optional
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# Embeddings
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# Qdrant (self-hosted vector database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=  # Optional: only if auth enabled
QDRANT_DOCUMENTS_COLLECTION=documents
QDRANT_MEMORIES_COLLECTION=memories

# Pinecone (legacy - for existing RAG functionality)
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=llm-md-index
PINECONE_ENVIRONMENT=us-east-1

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_URL=redis://localhost:6379/2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=0.2

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Schema Storage
SCHEMAS_DIR=data/schemas
