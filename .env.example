# Database
# Option 1: Supabase (recommended for community)
# Find your connection string in Supabase Dashboard > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct connection for migrations (bypasses Supabase connection pooler):
# DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Option 2: Local PostgreSQL (auto-detected by start.sh from localhost URL)
# DATABASE_URL=postgresql://llm_user:llm_password@localhost:5432/llm_cli

# Database Password Encryption
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
DB_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY_44_CHARS

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...  # Optional
OLLAMA_BASE_URL=http://localhost:11434

# Default LLM settings
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=              # Optional: overrides provider-specific default
DEFAULT_LLM_TEMPERATURE=0.7

# LLM Provider-specific defaults
OPENAI_DEFAULT_MODEL=gpt-4o
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DEFAULT_MAX_TOKENS=4096
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_REQUEST_TIMEOUT=120.0

# Layer-4 orchestrator response-quality judge
# A cheap classifier LLM that decides whether the orchestrator's final answer
# actually resolves the user's question. On "unresolved", the orchestrator
# retries once; if still unresolved, the turn's credit is voided and the
# failure is captured into agent_failure_case for team review.
JUDGE_LLM_PROVIDER=openai          # or anthropic / ollama; empty → falls back to DEFAULT_LLM_PROVIDER
JUDGE_LLM_MODEL=gpt-5-mini         # recommended cheap classifier; empty → judge disabled (falls open)
JUDGE_TIMEOUT_SECONDS=10
JUDGE_ENABLED=true                 # kill-switch for the whole layer
JUDGE_HIGHLIGHT_ENABLED=true       # wrap meaningful numbers in ==...== so frontend renders them in orange

# Embeddings
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=100
EMBEDDING_MAX_RETRIES=3

# Qdrant (self-hosted vector database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=              # Optional: only if auth enabled
QDRANT_DOCUMENTS_COLLECTION=documents
QDRANT_MEMORIES_COLLECTION=memories
QDRANT_VECTOR_SIZE=3072      # Must match embedding dimensions

# RAG settings
RAG_DEFAULT_TOP_K=5
RAG_CONTEXT_SCORE_THRESHOLD=0.5
RAG_CONVERSATION_HISTORY_MESSAGES=6

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_URL=redis://localhost:6379/2

# Job/conversation TTL
JOB_TTL_SECONDS=604800           # 7 days
CONVERSATION_TTL_SECONDS=604800  # 7 days

# Celery task settings
CELERY_TASK_TIME_LIMIT=3600      # 1 hour
CELERY_MAX_RETRIES=3
CELERY_RETRY_BASE_COUNTDOWN=60   # seconds (exponential: 60, 120, 240)

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=0.2

# Upload / async processing thresholds
ASYNC_FILE_SIZE_THRESHOLD=100000   # 100KB: files above this are processed async
ASYNC_CHUNK_COUNT_THRESHOLD=20     # chunk count above this triggers async
UPLOAD_MAX_FILE_SIZE=52428800      # 50MB

# Chat file upload settings
CHAT_FILE_MAX_SIZE=10485760        # 10MB
CHAT_FILE_MAX_COUNT=5
CHAT_FILE_TTL_SECONDS=3600         # 1 hour
CHAT_FILE_CSV_MAX_ROWS=100
CHAT_FILE_PDF_MAX_PAGES=10
CHAT_FILE_TEXT_MAX_CHARS=50000

# Dataset upload settings
DATASET_MAX_FILE_SIZE=52428800     # 50MB
DATASET_MAX_ROWS=500000

# DigitalOcean Spaces (S3-compatible object storage)
DO_SPACES_BUCKET=ai365
DO_SPACES_BASE_PATH=bingo/dev      # Override per environment
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_REGION=sgp1
DO_SPACES_KEY_ID=                  # Optional: required for uploads
DO_SPACES_SECRET_KEY=              # Optional: required for uploads

# Server settings
APP_VERSION=0.1.0
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Logging
LOG_LEVEL=INFO

# Query guardrails
MAX_QUERY_ROWS=5000
QUERY_TIMEOUT_MS=30000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Schema Storage
SCHEMAS_DIR=data/schemas

# Bingo SSO
SSO_BASE_URL=https://sso.thebingo.ai
SSO_PUBLISHABLE_KEY=Bingo-Community       # app name (community) or pk_* key (enterprise)
SSO_SECRET_KEY=                           # sk_* key for backend (enterprise adds X-API-Key header)
SSO_TOKEN_CACHE_TTL=300                   # seconds (5 min)
SSO_WEBHOOK_SECRET=                       # Optional: webhook signature verification
SSO_REDIS_URL=redis://localhost:6379/3    # DB 3: SSO token cache

# Feature flags
ENABLE_GOVERNANCE=true      # Set to false to disable org/team/policy enforcement
