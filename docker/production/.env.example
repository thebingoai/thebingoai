# ─── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
EMAIL=admin@yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=llm_cli
POSTGRES_USER=llm_user
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# ─── Frontend ──────────────────────────────────────────────────────────────────
# In production, the browser hits /api/** which nginx proxies to the backend.
# Set to https://yourdomain.com/api if your frontend needs an absolute URL.
NUXT_PUBLIC_API_BASE_URL=/api

# ─── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# ─── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ─── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_DOCUMENTS_COLLECTION=documents
QDRANT_MEMORIES_COLLECTION=memories

# ─── Pinecone (legacy) ─────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=llm-md-index
PINECONE_ENVIRONMENT=us-east-1

# ─── Redis ─────────────────────────────────────────────────────────────────────
# These are set automatically via docker-compose environment overrides.
# Override here only if you use an external Redis.
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_URL=redis://redis:6379/2
# SSO_REDIS_URL=redis://redis:6379/3

# ─── Encryption / Auth ─────────────────────────────────────────────────────────
DB_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY_44_CHARS

# ─── SSO Authentication ────────────────────────────────────────────────────────
SSO_BASE_URL=https://sso.thelead.io
SSO_PUBLISHABLE_KEY=pk_...
SSO_SECRET_KEY=sk_...
SSO_TOKEN_CACHE_TTL=300
SSO_WEBHOOK_SECRET=...

# ─── App Settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_GOVERNANCE=true
CHUNK_SIZE=512
CHUNK_OVERLAP=0.2
SCHEMAS_DIR=data/schemas

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com
